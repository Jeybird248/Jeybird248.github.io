{% if site.news != blank %}
  <div class="news">
    {% if include.limit and site.announcements.limit %}
      {% assign news = site.news | reverse | slice: 0, site.announcements.limit %}
    {% else %}
      {% assign news = site.news | reverse %}
    {% endif %}
    {% if news.size > 0 %}
      <div class="news-container{% if site.announcements.scrollable %} scrollable{% endif %}">
        <table class="table table-sm table-borderless">
          {% for item in news %}
            <tr>
              <th scope="row">{{ item.date | date: "%b %-d, %Y" }}</th>
              <td>
                {% if item.inline %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </table>
      </div>
    {% else %}
      <p>No news so far...</p>
    {% endif %}
  </div>
{% endif %}
