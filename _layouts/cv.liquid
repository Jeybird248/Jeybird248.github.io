---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
           target="_blank" rel="noopener noreferrer" class="float-right">
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {%- comment -%} ── General Information ── {%- endcomment -%}
    {% for entry in site.data.cv %}
      {% if entry.type == 'map' %}
        <div class="cv-info-grid">
          {% for content in entry.contents %}
            <div class="cv-info-item">
              <span class="cv-info-label">{{ content.name }}</span>
              <span class="cv-info-value">{{ content.value }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    {% endfor %}

    {%- comment -%} ── CV data as JS (safe: jsonify on pure YAML, no user HTML) ── {%- endcomment -%}
    <script>var CV_RAW_DATA = {{ site.data.cv | jsonify }};</script>

    {%- comment -%} ── News data as hidden HTML (avoids uglifier touching emoji HTML) ── {%- endcomment -%}
    <div id="cv-news-src" style="display:none" aria-hidden="true">
      {%- assign sorted_news = site.news | sort: "date" | reverse -%}
      {%- for item in sorted_news -%}
        {%- if item.inline -%}
          <span
            data-year="{{ item.date | date: '%Y' }}"
            data-date="{{ item.date | date: '%b %Y' }}"
            data-text="{{ item.content | strip_html | strip | escape }}"
          ></span>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ── Filter buttons ── {%- endcomment -%}
    <div class="tl-filters">
      <button class="tl-filter active" data-filter="all">All</button>
      <button class="tl-filter" data-filter="education">
        <span class="tl-filter-dot" style="background:#3498db"></span>Education
      </button>
      <button class="tl-filter" data-filter="experience">
        <span class="tl-filter-dot" style="background:#9b59b6"></span>Experience
      </button>
      <button class="tl-filter" data-filter="milestone">
        <span class="tl-filter-dot" style="background:#f1c40f"></span>Milestones
      </button>
    </div>

    {%- comment -%} ── Timeline (built by JS) ── {%- endcomment -%}
    <div class="cv-timeline" id="cv-timeline"></div>

    {%- comment -%} ── Talks & Awards (built by JS) ── {%- endcomment -%}
    <div id="cv-lists"></div>
  </article>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const rawSections = CV_RAW_DATA;
  const newsItems = Array.from(document.querySelectorAll("#cv-news-src span")).map(function(el) {
    return {
      year: el.dataset.year,
      text: el.dataset.text,
      date: el.dataset.date
    };
  });
  const catColors = { education: "#3498db", experience: "#9b59b6", project: "#e67e22", milestone: "#f1c40f" };

  // ── Flatten cv.yml sections into events ──
  const allEvents = [];
  const listSections = [];

  rawSections.forEach(function(section) {
    if (section.type === "map") return; // handled by Liquid above

    if (section.type === "list") {
      listSections.push({ title: section.title, items: section.contents });
      return;
    }

    if (section.type === "time_table") {
      var cat = "experience";
      if (section.title && section.title.toLowerCase().indexOf("education") !== -1) cat = "education";
      else if (section.title && section.title.toLowerCase().indexOf("project") !== -1) cat = "project";

      (section.contents || []).forEach(function(entry) {
        // Flatten description items to strings
        var desc = [];
        (entry.description || []).forEach(function(item) {
          if (typeof item === "string") {
            desc.push(item);
          } else if (item && item.contents) {
            desc.push((item.title || "") + ": " + item.contents.join(", "));
          } else if (item && item.title) {
            desc.push(item.title + (item.value ? ": " + item.value : ""));
          }
        });

        allEvents.push({
          year: entry.year ? String(entry.year) : "",
          title: entry.title || "",
          institution: entry.institution || "",
          category: cat,
          description: desc
        });
      });
    }
  });

  // ── Add news as milestones ──
  newsItems.forEach(function(n) {
    allEvents.push({
      year: n.year,
      title: n.text,
      institution: "",
      category: "milestone",
      date: n.date,
      description: []
    });
  });

  // ── Separate projects from timeline events ──
  const timelineRaw = allEvents.filter(e => e.category !== "project");
  const projects    = allEvents.filter(e => e.category === "project");

  // ── Group timeline events by start year ──
  function startYear(y) {
    if (!y) return 0;
    return parseInt(String(y).split(/\s*-\s*/)[0]) || 0;
  }

  const yearMap = {};
  timelineRaw.forEach(e => {
    const sy = startYear(e.year);
    if (!yearMap[sy]) yearMap[sy] = [];
    yearMap[sy].push(e);
  });

  const sortedYears = Object.keys(yearMap).map(Number).sort((a, b) => b - a);

  // ── Render timeline ──
  const tl = document.getElementById("cv-timeline");

  sortedYears.forEach((yr, idx) => {
    const group = yearMap[yr];
    const node = document.createElement("div");
    node.className = "tl-event " + (idx % 2 === 0 ? "tl-left" : "tl-right");
    // store all categories present in this group for filtering
    const cats = [...new Set(group.map(e => e.category))];
    node.dataset.categories = cats.join(",");

    // pick dot color: prioritize education > experience > milestone
    const dotCat = cats.includes("education") ? "education"
                 : cats.includes("experience") ? "experience"
                 : cats[0];

    let html = '<div class="tl-dot tl-dot--' + dotCat + '"></div>';
    html += '<div class="tl-card">';
    html += '<span class="tl-year-marker">' + yr + '</span>';

    group.forEach((entry, ei) => {
      const hasBullets = entry.description && entry.description.length > 0;
      const isMilestone = entry.category === "milestone";

      html += '<div class="tl-entry' + (ei > 0 ? ' tl-entry-border' : '') + (isMilestone ? ' tl-entry--milestone' : '') + '">';

      if (isMilestone) {
        // Milestones: render the HTML content (preserves links), show month+year
        html += '<div class="tl-milestone-body">';
        html += '<i class="fa-solid fa-star tl-milestone-icon"></i>';
        html += '<div>';
        html += '<div class="tl-milestone-text">' + entry.title + '</div>';
        if (entry.date) html += '<span class="tl-year-range">' + entry.date + '</span>';
        html += '</div></div>';
      } else {
        // Regular entries
        html += '<div class="tl-entry-head">';
        html += '<div>';
        if (entry.title) html += '<h4 class="tl-title">' + entry.title + '</h4>';
        if (entry.institution) html += '<p class="tl-institution">' + entry.institution + '</p>';
        if (entry.year) html += '<span class="tl-year-range">' + entry.year + '</span>';
        html += '</div>';
        if (hasBullets) {
          html += '<button class="tl-expand" aria-label="Toggle details"><i class="fa-solid fa-chevron-down"></i></button>';
        }
        html += '</div>';

        if (hasBullets) {
          html += '<ul class="tl-detail">';
          entry.description.forEach(d => {
            html += '<li>' + d + '</li>';
          });
          html += '</ul>';
        }
      }

      html += '</div>'; // .tl-entry
    });

    html += '</div>'; // .tl-card
    node.innerHTML = html;
    tl.appendChild(node);
  });

  // ── Render projects grid ──
  if (projects.length > 0) {
    document.getElementById("projects-heading").style.display = "";
    const grid = document.getElementById("cv-projects");
    projects.forEach(p => {
      const card = document.createElement("div");
      card.className = "cv-project-card";
      let h = '';
      if (p.title) h += '<h4>' + p.title + '</h4>';
      if (p.year) h += '<span class="tl-year-range">' + p.year + '</span>';
      if (p.description && p.description.length > 0) {
        h += '<ul>';
        p.description.forEach(d => { h += '<li>' + d + '</li>'; });
        h += '</ul>';
      }
      card.innerHTML = h;
      grid.appendChild(card);
    });
  }

  // ── Render lists (talks, awards) ──
  const listsEl = document.getElementById("cv-lists");
  listSections.forEach(list => {
    const sec = document.createElement("div");
    sec.className = "cv-minor-section";
    let h = '<h3>' + list.title + '</h3><ul>';
    list.items.forEach(item => { h += '<li>' + item + '</li>'; });
    h += '</ul>';
    sec.innerHTML = h;
    listsEl.appendChild(sec);
  });

  // ── Expand / collapse ──
  document.querySelectorAll(".tl-expand").forEach(btn => {
    btn.addEventListener("click", function () {
      this.closest(".tl-entry").classList.toggle("expanded");
    });
  });

  // ── Filters ──
  const allNodes = Array.from(tl.querySelectorAll(".tl-event"));

  document.querySelectorAll(".tl-filter").forEach(btn => {
    btn.addEventListener("click", function () {
      document.querySelectorAll(".tl-filter").forEach(b => b.classList.remove("active"));
      this.classList.add("active");
      const f = this.dataset.filter;
      let visIdx = 0;
      allNodes.forEach(node => {
        const cats = node.dataset.categories.split(",");
        if (f === "all" || cats.includes(f)) {
          node.style.display = "";
          node.classList.remove("tl-left", "tl-right");
          node.classList.add(visIdx % 2 === 0 ? "tl-left" : "tl-right");
          visIdx++;
        } else {
          node.style.display = "none";
        }
      });
    });
  });

  // ── Scroll-triggered fade-in ──
  if ("IntersectionObserver" in window) {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("tl-visible");
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    allNodes.forEach(e => obs.observe(e));
  } else {
    allNodes.forEach(e => e.classList.add("tl-visible"));
  }
});
</script>
